---
const { post } = Astro.props;
const tags = post.tags?.slice(0, 3) ?? [];
---

<li class="blog-post__preview">
	<a href={post.href}>
		<div class="blog-post__index" aria-hidden="true"></div>
		<div class="blog-post__body">
			<div class="blog-post__meta-row">
				{post.dateLabel && <p class="blog-post__date">{post.dateLabel}</p>}
				{tags.length > 0 && <ul class="blog-post__tags" aria-label="Post tags">
					{tags.map((tag) => <li>{tag}</li>)}
				</ul>}
			</div>
			<h2>{post.title}</h2>
			{post.excerpt && <p class="blog-post__excerpt">{post.excerpt}</p>}
		</div>
	</a>
</li>

<style>
	.blog-post__preview {
		list-style: none;
		counter-increment: posts;
		border-bottom: 1px solid rgba(23, 23, 23, 0.12);
	}
	.blog-post__preview a {
		display: grid;
		grid-template-columns: 3.8rem minmax(0, 1fr);
		gap: clamp(1rem, 2.4vw, 1.9rem);
		padding: clamp(1.45rem, 2.6vw, 2.05rem) 0;
		color: inherit;
		text-decoration: none;
	}
	.blog-post__index::before {
		content: counter(posts, decimal-leading-zero);
		font-family: var(--theme-font-family-serif);
		font-size: 1.12rem;
		font-weight: 700;
		line-height: 1;
		color: color-mix(in srgb, var(--theme-accent) 78%, var(--theme-muted));
	}
	.blog-post__index {
		position: relative;
		padding-top: 0.18rem;
	}
	.blog-post__index::after {
		content: '';
		position: absolute;
		top: 1.8rem;
		left: 0.1rem;
		width: 1.75rem;
		height: 1px;
		background: color-mix(in srgb, var(--theme-accent) 58%, transparent);
	}
	.blog-post__preview a:hover h2 {
		color: #117d79;
	}
	.blog-post__body {
		min-width: 0;
	}
	.blog-post__meta-row {
		margin-bottom: 0.55rem;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.52rem 0.8rem;
	}
	.blog-post__date {
		margin: 0;
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #17424b;
	}
	.blog-post__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.blog-post__tags li {
		font-size: 0.72rem;
		font-weight: 700;
		line-height: 1;
		color: color-mix(in srgb, var(--theme-muted) 84%, transparent);
	}
	.blog-post__tags li::before {
		content: '/';
		margin-right: 0.4rem;
		color: color-mix(in srgb, #d78370 70%, transparent);
	}
	.blog-post__preview h2 {
		margin: 0 0 0.55rem;
		font-family: var(--theme-font-family-serif);
		font-size: clamp(1.55rem, 2.15vw, 2.1rem);
		font-weight: 700;
		line-height: 1.14;
		letter-spacing: 0;
		transition: color var(--theme-transition);
		text-wrap: balance;
		color: #071725;
	}
	.blog-post__excerpt {
		max-width: 42rem;
		margin: 0;
		font-size: 1rem;
		line-height: 1.68;
		color: #56666f;
	}
	@media (max-width: 860px) {
		.blog-post__preview a {
			grid-template-columns: 3rem minmax(0, 1fr);
			gap: 0.9rem;
			padding: 1.25rem 0;
		}
		.blog-post__index::before {
			font-size: 0.96rem;
		}
	}
	@media (max-width: 560px) {
		.blog-post__preview a {
			grid-template-columns: 1fr;
			gap: 0.6rem;
		}
		.blog-post__index {
			padding-top: 0;
		}
		.blog-post__index::after {
			left: 2.55rem;
			top: 0.48rem;
		}
		.blog-post__tags {
			width: 100%;
		}
	}
</style>
