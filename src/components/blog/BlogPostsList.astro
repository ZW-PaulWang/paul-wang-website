---
import BlogPostPreview from './BlogPostPreview.astro';

const { posts } = Astro.props;
---

<ul class="blog-posts-list__list">
	{posts?.map((post) => <BlogPostPreview post={post} />)}
</ul>

<style>
	.blog-posts-list__list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0;
		counter-reset: posts;
	}
</style>
