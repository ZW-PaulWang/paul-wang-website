---
const { href, unelevated, outlined, customIcon, onPrimary, newTab } =
  Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  class={`btn ${unelevated && `btn--unelevated`} ${
    outlined && `btn--outlined`
  } ${onPrimary && `btn--on-primary`}`}
  href={href}
  target={`${newTab ? '_blank': ``}`}
  rel={`${newTab ? 'noopener noreferrer' : ``}`}
>
  <slot />
  {customIcon && <span class="custom-icon__span"><slot name="icon">custom_icon</slot></span>}
</Tag>

<style>
  .btn {
    width: fit-content;
    padding: 0.65rem 1.1rem;
    margin-bottom: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.18), transparent),
      var(--theme-primary);
    color: var(--theme-on-primary);
    border: 1px solid transparent;
    border-radius: var(--theme-button-border-radius);
    box-shadow: var(--theme-shadow-sm), inset 0 1px 0 rgba(255, 255, 255, 0.22);
    font-weight: 700;
    letter-spacing: 0.01em;
    transition:
      transform var(--theme-transition),
      box-shadow var(--theme-transition),
      background-color var(--theme-transition),
      border-color var(--theme-transition);
  }
  .btn:hover {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.18), transparent),
      var(--theme-primary-hover);
    box-shadow: var(--theme-shadow-md), inset 0 1px 0 rgba(255, 255, 255, 0.24);
    transform: translateY(-1px);
  }
  .btn--unelevated {
    background: transparent;
    color: var(--theme-on-bg);
    border-color: var(--theme-outline);
    box-shadow: none;
  }
  .btn--unelevated:hover {
    background: rgba(255, 255, 255, 0.42);
    opacity: 1;
  }
  .btn--outlined {
    color: var(--theme-primary);
    background: var(--theme-glass-bg);
    backdrop-filter: blur(var(--theme-backdrop-blur));
    -webkit-backdrop-filter: blur(var(--theme-backdrop-blur));
    border-color: var(--theme-outline-strong);
  }
  .btn--outlined:hover {
    background: var(--theme-primary);
    color: var(--theme-on-primary);
    border-color: transparent;
  }
  .custom-icon__span {
    margin-left: 0.25rem;
    display: flex;
    align-items: center;
  }

  .custom-icon__span :global(svg) {
    width: 24px;
    height: 24px;
  }

  a.btn {
    text-decoration: none;
  }
  button.btn {
    cursor: pointer;
    outline: none;
  }
  .btn:focus-visible {
    outline: 3px solid rgba(70, 113, 170, 0.32);
    outline-offset: 3px;
  }
</style>
