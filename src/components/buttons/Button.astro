---
const { href, unelevated, outlined, customIcon, onPrimary, newTab } =
  Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  class={`btn ${unelevated && `btn--unelevated`} ${
    outlined && `btn--outlined`
  } ${onPrimary && `btn--on-primary`}`}
  href={href}
  target={`${newTab ? '_blank': ``}`}
  rel={`${newTab ? 'noopener noreferrer' : ``}`}
>
  <slot />
  {customIcon && <span class="custom-icon__span"><slot name="icon">custom_icon</slot></span>}
</Tag>

<style>
  .btn {
    width: fit-content;
    padding: 0.5rem 0.75rem;
    margin-bottom: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    background: transparent;
    color: var(--theme-on-bg);
    border: 1px solid var(--theme-outline);
    border-radius: var(--theme-button-border-radius);
    box-shadow: none;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0;
    transition:
      background-color var(--theme-transition),
      border-color var(--theme-transition);
  }
  .btn:hover {
    background: var(--theme-surface-2);
    border-color: var(--theme-outline-strong);
  }
  .btn--unelevated {
    background: transparent;
    color: var(--theme-on-bg);
    border-color: var(--theme-outline);
    box-shadow: none;
  }
  .btn--unelevated:hover {
    background: color-mix(in srgb, var(--theme-surface-1) 88%, white);
    opacity: 1;
  }
  .btn--outlined {
    color: var(--theme-primary);
    background: transparent;
    border-color: var(--theme-outline-strong);
  }
  .btn--outlined:hover {
    background: var(--theme-surface-2);
    border-color: var(--theme-outline-strong);
  }
  .custom-icon__span {
    margin-left: 0.25rem;
    display: flex;
    align-items: center;
  }

  .custom-icon__span :global(svg) {
    width: 24px;
    height: 24px;
  }

  a.btn {
    text-decoration: none;
  }
  button.btn {
    cursor: pointer;
    outline: none;
  }
  .btn:focus-visible {
    outline: 3px solid var(--theme-focus-ring);
    outline-offset: 3px;
  }
</style>
