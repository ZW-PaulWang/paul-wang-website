---
const { href, imgSrc, title } = Astro.props;
---

<div class="feature-card__card">
	<a class="feature-card__link" {href}>
		<div class="featured-card__content">
			<h3 class="feature-card__title">{title}</h3>
			<!-- I would like to swap this out with Astro's Image integration soon but was having some issues with it at the moment so we're going old school here. -->
			<picture>
				<source srcset={`${imgSrc}.webp`} type="image/webp" />
				<img
					class="feature-card__img"
					src={`${imgSrc}.png`}
					alt={title}
					loading="lazy"
					width="780"
					height="585"
					decoding="async"
				/>
			</picture>
		</div>
	</a>
</div>

<style>
	.feature-card__card {
		height: 100%;
		overflow: hidden;
		background: linear-gradient(
				180deg,
				rgba(255, 255, 255, 0.88),
				rgba(255, 255, 255, 0.62)
			),
			var(--theme-surface-1);
		color: var(--theme-on-surface-1);
		border: 1px solid var(--theme-outline);
		border-radius: calc(var(--theme-shape-radius) * 0.9);
		box-shadow: var(--theme-shadow-md), var(--theme-shadow-inset);
	}
	.feature-card__link {
		min-height: 100%;
		display: block;
		text-decoration: none;
	}
	.featured-card__content {
		padding: 1rem 1rem 0 1rem;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		overflow-y: hidden;
	}
	.featured-card__content picture {
		width: 100%;
		height: 100%;
	}
	.feature-card__card .feature-card__img {
		--image-shadow: 0 18px 36px rgba(16, 24, 40, 0.14);
		margin: 0 auto;
		width: min(100%, 390px);
		height: auto;
		object-fit: cover;
		border-radius: calc(var(--theme-shape-radius) * 0.65);
		box-shadow: var(--image-shadow);
		transform: translateY(0.6rem);
		transition: transform var(--theme-transition),
			box-shadow var(--theme-transition);
	}
	.feature-card__card:hover .feature-card__img {
		transform: translateY(0);
	}
	.feature-card__title {
		font-family: var(--theme-font-family-sans);
		margin-bottom: 0.85rem;
		font-size: var(--font-size-md);
	}
</style>
