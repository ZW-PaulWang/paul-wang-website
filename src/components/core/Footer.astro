---
import { Icon } from 'astro-icon/components';
import Container  from '../core/Container.astro';
import Plug from './Plug.astro';

const { footerSocials, footerLists, copyrightName, background, color, showPlug: showPlug = true } =
  Astro.props;
---

<footer
  style={background && `--footer-bg:${background}; --footer-color:${color}`}
>
	<Container>
		<div class="footer-grid__container">
			<div class="footer-brand__container footer-panel">
				<div>
					<slot name="logo" />
				</div>
				<p class="footer-brand__copy">
					A focused personal site for research, essays, travel notes, and tennis stories.
				</p>
				<ul class="footer-socials__list">
					{
						footerSocials.map((social) => (
							<li class="footer-socials__item">
                <a
                  href={social.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="footer-socials__link"
                  title={`Open ${social.name} profile`}
                >
                  <Icon name={social.icon} width={24} height={24} />
                </a>
              </li>
            ))
          }
        </ul>
			</div>
			{
				footerLists.map((list) => (
					<div class="footer-panel">
						<p><strong>{list.title}</strong></p>
						<ul class="footer-link__list">
							{list.items.map((item) => (
								<li>
                  <a href={item.slug}>{item.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div class="footer-copyright__container">
      {showPlug && <Plug/>}
      <p>Copyright &copy; {new Date().getFullYear()} {copyrightName}</p>
    </div>

  </Container>
</footer>

<style>
  footer {
    --footer-bg: var(--theme-primary);
    --footer-color: var(--theme-on-primary);
    margin: 0 1rem 1rem;
    padding: 1.25rem 0 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent),
      var(--footer-bg);
    color: var(--footer-color);
    border: 1px solid var(--theme-outline);
    border-radius: calc(var(--theme-shape-radius) * 1.05);
    box-shadow: var(--theme-shadow-lg);
  }
  .footer-grid__container {
    padding: 1rem 0 1rem 0;
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  .footer-panel {
    min-height: 100%;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: calc(var(--theme-shape-radius) * 0.8);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }
  .footer-brand__copy {
    max-width: 24rem;
    color: rgba(255, 255, 255, 0.76);
  }
  .footer-socials__list {
    margin: 1rem 0;
    padding: 0;
    display: flex;
    list-style: none;
    gap: 0.5rem;
  }
  .footer-link__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .footer-link__list li {
    margin-bottom: 0.5rem;
  }
  .footer-link__list li a {
    text-decoration: none;
    color: rgba(255, 255, 255, 0.76);
  }
  .footer-link__list li a:hover {
    color: #fff;
  }
  .footer-socials__link {
    width: 2.75rem;
    height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.12);
    transition: transform var(--theme-transition), background-color var(--theme-transition);
  }
  .footer-socials__link:hover,
  .footer-socials__link:focus-visible {
    background: rgba(255, 255, 255, 0.18);
    transform: translateY(-1px);
  }
  .footer-copyright__container {
    padding: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-copyright__container p {
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.76);
  }
  @media (max-width: 768px) {
    .footer-grid__container :first-child {
      grid-column: 1/-1;
    }
    .footer-grid__container {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    footer {
      margin: 0 0.75rem 0.75rem;
    }
    .footer-grid__container {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .footer-copyright__container {
      flex-direction: column;
    }
  }
</style>
