---
import { Icon } from 'astro-icon/components';
import Container from '../core/Container.astro';
const {
	footerSocials,
	footerLists,
	copyrightName,
	background,
	color,
} = Astro.props;

const isExternalLink = (url) => /^https?:\/\//.test(url) || url.startsWith('mailto:');
---

<footer style={background && `--footer-bg:${background}; --footer-color:${color}`}>
	<Container>
		<div class="footer-shell">
			<div class="footer-intro">
				<div>
					<slot name="logo" />
				</div>
				<p class="footer-kicker">Paul Wang</p>
				<p class="footer-copy">
					A personal academic site for selected writing, projects, and contact information.
				</p>
				<ul class="footer-socials__list">
					{
						footerSocials.map((social) => (
							<li class="footer-socials__item">
								<a
									href={social.url}
									target="_blank"
									rel="noopener noreferrer"
									class="footer-socials__link"
									title={`Open ${social.name} profile`}
								>
									<Icon name={social.icon} width={20} height={20} />
									<span>{social.name}</span>
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<div class="footer-nav">
				{
					footerLists.map((list) => (
						<section class="footer-nav__group">
							<p class="footer-nav__title">{list.title}</p>
							<ul class="footer-link__list">
								{list.items.map((item) => (
									<li>
										<a
											href={item.slug}
											target={isExternalLink(item.slug) ? '_blank' : undefined}
											rel={isExternalLink(item.slug) ? 'noopener noreferrer' : undefined}
										>
											{item.title}
										</a>
									</li>
								))}
							</ul>
						</section>
					))
				}
			</div>
		</div>

		<div class="footer-meta">
			<p>Copyright &copy; {new Date().getFullYear()} {copyrightName}</p>
		</div>
	</Container>
</footer>

<style>
	footer {
		--footer-bg: var(--theme-surface-1);
		--footer-color: var(--theme-on-surface-1);
		--footer-muted: color-mix(in srgb, var(--footer-color) 62%, var(--footer-bg));
		--footer-soft-line: color-mix(in srgb, var(--footer-color) 12%, var(--footer-bg));
		margin: 0 1rem 1rem;
		padding: 1.8rem 0 0.95rem;
		background: var(--footer-bg);
		color: var(--footer-color);
		border-top: 1px solid var(--footer-soft-line);
		border-right: 0;
		border-bottom: 0;
		border-left: 0;
		border-radius: 0;
		box-shadow: none;
	}
	.footer-shell {
		display: grid;
		grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
		gap: clamp(1.5rem, 3vw, 3rem);
		align-items: start;
	}
	.footer-intro {
		padding-right: clamp(0rem, 2vw, 1.5rem);
	}
	.footer-kicker {
		margin: 1rem 0 0.4rem;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--footer-muted);
	}
	.footer-copy {
		max-width: 26rem;
		margin-bottom: 1.2rem;
		font-size: 0.95rem;
		line-height: 1.65;
		color: var(--footer-muted);
	}
	.footer-socials__list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
	.footer-socials__link {
		padding: 0.48rem 0.68rem;
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		text-decoration: none;
		border-radius: var(--theme-button-border-radius);
		color: var(--footer-color);
		background: transparent;
		border: 1px solid var(--footer-soft-line);
		transition:
			background-color var(--theme-transition),
			border-color var(--theme-transition);
	}
	.footer-socials__link:hover,
	.footer-socials__link:focus-visible {
		border-color: color-mix(in srgb, var(--footer-color) 18%, var(--footer-bg));
		background: var(--theme-surface-2);
	}
	.footer-socials__link span {
		font-size: 0.86rem;
		font-weight: 600;
	}
	.footer-nav {
		padding-top: 0.4rem;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
		gap: 1.5rem;
	}
	.footer-nav__group {
		padding-left: 1.1rem;
		border-left: 1px solid var(--footer-soft-line);
	}
	.footer-nav__title {
		margin-bottom: 0.85rem;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--footer-muted);
	}
	.footer-link__list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.65rem;
	}
	.footer-link__list a {
		text-decoration: none;
		color: var(--footer-color);
		font-weight: 600;
		font-size: 0.9rem;
		line-height: 1.35;
		transition: color var(--theme-transition), transform var(--theme-transition);
	}
	.footer-link__list a:hover,
	.footer-link__list a:focus-visible {
		color: var(--theme-muted);
	}
	.footer-meta {
		margin-top: 1.4rem;
		padding-top: 0.9rem;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		border-top: 1px solid var(--footer-soft-line);
	}
	.footer-meta p {
		margin: 0;
		font-size: var(--font-size-sm);
		color: var(--footer-muted);
	}
	@media (max-width: 900px) {
		.footer-shell {
			grid-template-columns: 1fr;
		}
		.footer-intro {
			padding-right: 0;
		}
		.footer-nav {
			grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
		}
		.footer-nav__group {
			padding-left: 0;
			padding-top: 1rem;
			border-left: 0;
			border-top: 1px solid var(--footer-soft-line);
		}
	}
	@media (max-width: 680px) {
		footer {
			margin: 0 0.75rem 0.75rem;
		}
		.footer-nav {
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		.footer-meta {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
