---
import { Container } from '@components/odyssey-theme';
---

<Container>
	<section class="hero-section__section">
		<div class="hero-section__visual" aria-hidden="true">
			<img
				src="/assets/images/home/paul-quantitative-portrait.png"
				alt=""
				id="home-hero-image"
			/>
		</div>
		<div class="hero-section__text">
			<p class="hero-section__brand">Predoctoral Research Associate</p>
			<h1>
				<span>Paul <span class="hero-section__nickname">(Zechong)</span></span>
				<span>Wang</span>
			</h1>
			<p class="hero-section__lede">
				I work across empirical finance, data analysis, and applied quantitative
				projects, with an emphasis on careful methods and clear communication.
			</p>
			<p class="hero-section__location">
				Harvard Business School · Corporate Finance and Data Analysis
			</p>
			<div class="hero-btns__container">
				<a class="hero-text-link" href="/about-me">About</a>
				<a class="hero-text-link" href="mailto:zw2685@uchicago.edu">Email</a>
				<a class="hero-text-link" href="https://www.linkedin.com/in/wang1023/">LinkedIn</a>
			</div>
		</div>
	</section>
</Container>

<style>
	.hero-section__section {
		--home-accent: #117d79;
		--home-accent-deep: #123d46;
		--home-warm: #d78370;
		--hero-image-shift: clamp(0rem, 1.2vw, 1.75rem);
		position: relative;
		isolation: isolate;
		width: 100vw;
		min-height: 100svh;
		margin: 0 0 0 calc(50% - 50vw);
		padding:
			clamp(5.6rem, 10vw, 7.4rem)
			max(clamp(1.4rem, 8vw, 7rem), calc((100vw - var(--container-max-width)) / 2 + 1.5rem))
			clamp(2.2rem, 5vw, 4rem);
		display: flex;
		align-items: center;
		overflow: hidden;
		border-bottom: 0;
		background: #ffffff;
	}
	.hero-section__section::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: 1;
		background:
			linear-gradient(90deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 255, 255, 0.94) 30%, rgba(255, 255, 255, 0.58) 48%, rgba(255, 255, 255, 0) 72%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(237, 251, 250, 0.06));
		pointer-events: none;
	}
	.hero-section__section::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 1;
		height: 22%;
		background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.62));
		pointer-events: none;
	}
	.hero-section__visual {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
	}
	.hero-section__visual img {
		width: calc(100% + var(--hero-image-shift));
		height: 100%;
		max-width: none;
		object-fit: cover;
		object-position: center;
		transform: translateX(var(--hero-image-shift));
		filter: saturate(1.03) contrast(1.02);
	}
	.hero-section__text {
		position: relative;
		z-index: 2;
		display: flex;
		flex-direction: column;
		justify-content: center;
		width: min(40rem, 41vw);
		margin-top: clamp(0rem, 2vw, 1.75rem);
	}
	.hero-section__brand {
		margin-bottom: 0.95rem;
		font-size: clamp(0.72rem, 0.82vw, 0.86rem);
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--home-accent);
	}
	h1 {
		max-width: 13.5ch;
		margin-bottom: 1.35rem;
		font-family: Georgia, 'Times New Roman', serif;
		font-size: clamp(3.3rem, 4.25vw, 4.85rem);
		font-weight: 600;
		line-height: 0.98;
		letter-spacing: 0;
		text-wrap: balance;
		color: #071725;
	}
	h1 > span {
		display: block;
		white-space: nowrap;
	}
	.hero-section__nickname {
		display: inline;
	}
	.hero-section__lede {
		max-width: 31rem;
		margin-bottom: 0.85rem;
		font-size: clamp(1rem, 1.18vw, 1.16rem);
		line-height: 1.75;
		color: #435560;
	}
	.hero-section__location {
		width: fit-content;
		margin-bottom: 1.9rem;
		padding-top: 0.72rem;
		border-top: 1px solid color-mix(in srgb, var(--home-warm) 54%, transparent);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: color-mix(in srgb, var(--home-accent) 72%, #071725);
	}
	.hero-btns__container {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.7rem 1.45rem;
	}
	.hero-text-link {
		position: relative;
		display: inline-flex;
		align-items: center;
		text-decoration: none;
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.13em;
		text-transform: uppercase;
		color: #102b34;
		border-bottom: 1px solid color-mix(in srgb, var(--home-warm) 72%, transparent);
	}
	.hero-text-link:hover {
		color: var(--home-accent);
		border-color: currentColor;
	}
	@media (max-width: 980px) {
		.hero-section__section {
			--hero-image-shift: 0rem;
			min-height: auto;
			padding:
				clamp(20rem, 62vw, 31rem)
				clamp(1.25rem, 5vw, 2rem)
				clamp(2.6rem, 7vw, 4rem);
			align-items: flex-start;
		}
		h1 {
			max-width: 100%;
		}
		h1 > span {
			white-space: normal;
		}
		.hero-section__visual {
			height: clamp(20rem, 62vw, 31rem);
			bottom: auto;
		}
		.hero-section__visual img {
			width: 100%;
			object-position: 58% center;
			transform: none;
		}
		.hero-section__section::before {
			background:
				linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.08) 52%, rgba(255, 255, 255, 0.98) 100%),
				linear-gradient(90deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0));
		}
		.hero-section__text {
			width: 100%;
			max-width: 42rem;
			margin-top: 0;
		}
	}
	@media (max-width: 640px) {
		.hero-section__section {
			padding-top: clamp(17rem, 72vw, 24rem);
			padding-bottom: 2.5rem;
		}
		h1 {
			font-size: clamp(2.75rem, 12vw, 3.35rem);
		}
		.hero-section__nickname {
			display: block;
		}
		.hero-section__location {
			width: 100%;
			font-size: 0.72rem;
			line-height: 1.45;
			overflow-wrap: anywhere;
		}
		.hero-section__visual {
			height: clamp(17rem, 72vw, 24rem);
		}
	}
</style>
