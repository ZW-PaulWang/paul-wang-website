---
import { parse, isBefore, format } from 'date-fns';
import { Container, BlogPostsList } from '@components/odyssey-theme';
import Layout from '../../layouts/Page.astro';

const posts = await Astro.glob('./posts/*.mdx').then(posts =>
	posts
		.map(({ frontmatter, url }) => ({
			title: frontmatter.title,
			description: frontmatter.description,
			authors: frontmatter.authors,
			publishDate: parse(frontmatter.publishDate, 'MMMM d, yyyy', new Date()),
			dateLabel: frontmatter.publishDate
				? format(
						parse(frontmatter.publishDate, 'MMMM d, yyyy', new Date()),
						'MMM d, yyyy'
				  )
				: '',
			featuredImage: frontmatter.featuredImage,
			excerpt: frontmatter.excerpt,
			tags: frontmatter.tags,
			href: url,
		}))
		.sort((a, b) => {
			if (isBefore(a.publishDate, b.publishDate)) return 1;
			if (isBefore(b.publishDate, a.publishDate)) return -1;
			return 0;
		})
);

const seo = {
	title: 'Blog | Paul (Zechong) Wang',
	description: 'Essays, reflections, and project notes by Paul (Zechong) Wang.',
};
---

<Layout {seo} hideFooter immersiveHeader>
	<section class="blog-index" aria-labelledby="blog-title">
		<Container>
			<div class="blog-index__layout">
				<aside class="blog-index__intro">
					<div class="blog-index__intro-inner">
						<div class="blog-index__rule" aria-hidden="true"></div>
						<p class="blog-index__eyebrow">Writing index</p>
						<h1 id="blog-title">Blog</h1>
						<p class="blog-index__subhead">
							Essays, reflections, and project notes.
						</p>
					</div>
				</aside>

				<div class="blog-index__posts" aria-label="Published posts">
					<div class="blog-index__posts-header">
						<p>Chronological index</p>
						<span>{posts.length} posts</span>
					</div>
					<BlogPostsList {posts} />
				</div>
			</div>
		</Container>
	</section>
</Layout>

<style>
	.blog-index {
		--blog-ink: #071725;
		--blog-teal: #17424b;
		--blog-accent: #d78370;
		position: relative;
		width: 100vw;
		min-height: calc(100svh - 5rem);
		margin-left: calc(50% - 50vw);
		padding: clamp(7rem, 11vw, 10rem) 0 clamp(5rem, 8vw, 7rem);
		overflow: hidden;
		background: linear-gradient(
				180deg,
				rgba(255, 255, 255, 0.88),
				rgba(237, 248, 251, 0.64) 34rem
			),
			linear-gradient(
				135deg,
				rgba(23, 66, 75, 0.1),
				rgba(215, 131, 112, 0.07) 45%,
				rgba(255, 255, 255, 0.76)
			),
			#fbfbfa;
	}
	.blog-index::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image: url('/assets/images/about/yosemite-about-hero.png');
		background-size: cover;
		background-position: center top;
		opacity: 0.055;
		filter: saturate(0.85) blur(1px);
		pointer-events: none;
	}
	.blog-index::after {
		content: '';
		position: absolute;
		inset: 0;
		background-image: linear-gradient(
			90deg,
			transparent 0,
			transparent calc(50% - min(640px, 43vw)),
			rgba(7, 23, 37, 0.055) calc(50% - min(640px, 43vw)),
			rgba(7, 23, 37, 0.055) calc(50% - min(640px, 43vw) + 1px),
			transparent calc(50% - min(640px, 43vw) + 1px),
			transparent calc(50% + min(640px, 43vw)),
			rgba(7, 23, 37, 0.055) calc(50% + min(640px, 43vw)),
			rgba(7, 23, 37, 0.055) calc(50% + min(640px, 43vw) + 1px),
			transparent calc(50% + min(640px, 43vw) + 1px)
		);
		pointer-events: none;
	}
	.blog-index__layout {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: minmax(16rem, 0.74fr) minmax(0, 1.26fr);
		gap: clamp(3rem, 7vw, 7rem);
		align-items: start;
		color: var(--blog-ink);
	}
	.blog-index__intro {
		position: sticky;
		top: clamp(5rem, 10vw, 7.5rem);
		min-height: 28rem;
		display: flex;
		align-items: flex-start;
	}
	.blog-index__intro-inner {
		max-width: 29rem;
		padding-left: clamp(0rem, 1vw, 0.6rem);
	}
	.blog-index__rule {
		width: 5.2rem;
		height: 2px;
		margin-bottom: 1.55rem;
		background: var(--blog-accent);
	}
	.blog-index__eyebrow {
		margin-bottom: 0.9rem;
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--blog-teal);
	}
	.blog-index h1 {
		max-width: 8ch;
		margin-bottom: 1.1rem;
		font-family: Georgia, 'Times New Roman', serif;
		font-size: clamp(4.2rem, 9vw, 7.15rem);
		font-weight: 600;
		line-height: 0.92;
		letter-spacing: 0;
		color: var(--blog-ink);
	}
	.blog-index__subhead {
		max-width: 21rem;
		margin: 0;
		font-size: clamp(1rem, 1.2vw, 1.16rem);
		line-height: 1.74;
		color: #435560;
	}
	.blog-index__posts {
		position: relative;
		padding-left: clamp(1.25rem, 3vw, 2.25rem);
		border-left: 1px solid rgba(23, 66, 75, 0.16);
	}
	.blog-index__posts::before {
		content: '';
		position: absolute;
		left: -1px;
		top: 0;
		width: 1px;
		height: 8.5rem;
		background: linear-gradient(180deg, var(--blog-teal), var(--blog-accent));
	}
	.blog-index__posts-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.85rem;
		padding-bottom: 0.9rem;
		border-bottom: 1px solid rgba(23, 23, 23, 0.13);
	}
	.blog-index__posts-header p,
	.blog-index__posts-header span {
		margin: 0;
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.11em;
		text-transform: uppercase;
	}
	.blog-index__posts-header p {
		color: var(--blog-teal);
	}
	.blog-index__posts-header span {
		color: color-mix(in srgb, var(--theme-muted) 82%, transparent);
	}
	@media (max-width: 900px) {
		.blog-index {
			padding-top: clamp(6.2rem, 15vw, 8rem);
		}
		.blog-index__layout {
			grid-template-columns: 1fr;
			gap: 2.35rem;
		}
		.blog-index__intro {
			position: relative;
			top: auto;
			min-height: 0;
		}
		.blog-index__intro-inner,
		.blog-index__subhead {
			max-width: 42rem;
		}
		.blog-index__posts {
			padding-left: 0;
			border-left: 0;
		}
		.blog-index__posts::before {
			display: none;
		}
	}
	@media (max-width: 640px) {
		.blog-index h1 {
			font-size: clamp(3.4rem, 18vw, 4.6rem);
		}
		.blog-index__posts-header {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.25rem;
		}
	}
</style>
