---
import { parse, format, isBefore } from 'date-fns';
import Layout from '../../../layouts/Page.astro'
import { Container } from '@components/odyssey-theme';
import BlogPostsList from '../../../components/blog/BlogPostsList.astro';
import {generateTagData} from '../../../utils/helpers.js'


export async function getStaticPaths() {
  const allPosts = await Astro.glob('../posts/*.mdx');
  const sortedPosts = allPosts
    .map((post) => ({
      ...post,
      parsedPublishDate: parse(post.frontmatter.publishDate, 'MMMM d, yyyy', new Date()),
    }))
    .sort((a, b) => {
      if (isBefore(a.parsedPublishDate, b.parsedPublishDate)) return 1;
      if (isBefore(b.parsedPublishDate, a.parsedPublishDate)) return -1;
      return 0;
    });
  const allCategoriesUnique = new Set();
  
  sortedPosts.forEach(post => {
    post.frontmatter.tags && post.frontmatter.tags.map(tag => {
      allCategoriesUnique.add(tag);
    })
  })
  
  const allCategoriesData = generateTagData(allCategoriesUnique);
   // map through the categories array
  return allCategoriesData.map((tag) => {
    // filter the posts that match the given category
    const posts = sortedPosts.filter((post) => post.frontmatter.tags.includes(tag.title))
      return {
      params: {slug: tag.slug}, 
      props: {
        tag: tag.title, 
        posts: posts
      }
    };
  });
}

const {tag, posts} = Astro.props;

const normalizedPosts = posts.map((post) => ({
  title: post.frontmatter.title,
  publishDate: parse(post.frontmatter.publishDate, 'MMMM d, yyyy', new Date()),
  dateLabel: format(parse(post.frontmatter.publishDate, 'MMMM d, yyyy', new Date()), 'MMM d, yyyy'),
  featuredImage: post.frontmatter.featuredImage,
  excerpt: post.frontmatter.excerpt,
  href: post.url,
}));

const seo ={
  title: `${tag} | Blog | Paul (Zechong) Wang`,
}
---

<Layout seo={seo}>
  <Container>
    <section class="tag-page__section"> 
      <div class="tag-page__hero">
        <p class="tag-page__eyebrow">Tag archive</p>
        <h1>{tag}</h1>
        <p class="tag-page__lede">Writing collected under this topic.</p>
      </div>
      <BlogPostsList posts={normalizedPosts} />
    </section>
  </Container>
</Layout>

<style>
.tag-page__section {
  min-height: 60vh;
  margin: var(--section-margin) auto;
}
.tag-page__hero {
  max-width: 38rem;
  margin-bottom: 1.3rem;
}
.tag-page__eyebrow {
  margin-bottom: 0.75rem;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--theme-primary);
}
.tag-page__hero h1 {
  margin-bottom: 0.55rem;
}
.tag-page__lede {
  margin-bottom: 0;
  color: var(--theme-muted);
}
</style>
