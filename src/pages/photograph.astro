			{ headline: 'Harbor glow', detail: 'Water, light, and skyline density make Hong Kong instantly legible.', tag: 'FRAME 01' },
			{ headline: 'Uphill city', detail: 'The topography gives every street a stronger sense of direction.', tag: 'FRAME 02' },
		]),
	},
	{
		id: 'los-cabos',
		city: 'Los Cabos',
		country: 'Mexico',
		continent: 'North America',
		kind: 'Coastal Region',
		lat: 22.8905,
		lng: -109.9167,
		accent: '#f8b05d',
		summary: 'Desert meeting ocean, bright air, and a coastline built around dramatic contrast.',
		details: [
			'Los Cabos works because the landscape has such a clean graphic logic: sand, rock, water, and sharp light.',
			'It feels expansive and restorative in a way that comes more from geography than from the built environment.',
		],
		highlights: ['Desert coast', 'Open horizon', 'Strong light'],
		photos: createPhotoSet('Los Cabos', 'Mexico', palettes.sunbelt, [
			{ headline: 'Desert edge', detail: 'Dry earth and blue water create the whole composition at once.', tag: 'FRAME 01' },
			{ headline: 'Pacific light', detail: 'The atmosphere feels clean, spare, and high-contrast.', tag: 'FRAME 02' },
		]),
	},
	{
		id: 'cancun',
		city: 'Cancun',
		country: 'Mexico',
		continent: 'North America',
		kind: 'City',
		lat: 21.1619,
		lng: -86.8515,
		accent: '#56c8d6',
		summary: 'Turquoise water, bright heat, and a beach city defined by color contrast.',
		details: [
			'Cancun stays in memory as a palette first: clear water, bright sand, and sky that rarely feels muted.',
			'Compared with denser urban stops, it is a place where the coastline does most of the storytelling.',
		],
		highlights: ['Turquoise water', 'Beach horizon', 'High-sun color'],
		photos: createPhotoSet('Cancun', 'Mexico', palettes.pacific, [
			{ headline: 'Caribbean blue', detail: 'The water carries most of the visual weight here.', tag: 'FRAME 01' },
			{ headline: 'Heat and light', detail: 'Cancun feels built around brightness and open coastlines.', tag: 'FRAME 02' },
		]),
	},
];

const groupedStops = Object.values(
	travelStops.reduce<
		Record<
			string,
			{ country: string; continent: string; accent: string; stops: TravelStop[] }
		>
	>((collection, stop) => {
		if (!collection[stop.country]) {
			collection[stop.country] = {
				country: stop.country,
				continent: stop.continent,
				accent: stop.accent,
				stops: [],
			};
		}
		collection[stop.country].stops.push(stop);
		return collection;
	}, {}),
);

const stopCount = travelStops.length;
const countryCount = groupedStops.length;
const continentCount = new Set(travelStops.map((stop) => stop.continent)).size;
const initialStop = travelStops[0];
---

<Layout
	seo={{
		title: 'Travel Atlas | Paul (Zechong) Wang',
		description: 'Interactive globe of the places Paul Wang has visited, with postcard-style city stories and image slots.',
	}}
>
	<Container>
		<section class="travel-atlas">
			<div class="travel-atlas__shell">
				<div class="travel-atlas__wash travel-atlas__wash--top"></div>
				<div class="travel-atlas__wash travel-atlas__wash--bottom"></div>

				<header class="travel-atlas__intro">
					<div class="travel-atlas__copy">
						<p class="travel-atlas__eyebrow">Travel Atlas</p>
						<h1>Places I've Been</h1>
						<p class="travel-atlas__lead">
							A globe-first travel page that turns every stop into a postcard. Drag or scroll
							the globe, pick a highlighted marker, and open a city story with notes and photo
							slides.
						</p>
					</div>

					<div class="travel-atlas__facts">
						<div class="travel-atlas__stat">
							<span class="travel-atlas__stat-value">{stopCount}</span>
							<span class="travel-atlas__stat-label">Stops</span>
						</div>
						<div class="travel-atlas__stat">
							<span class="travel-atlas__stat-value">{countryCount}</span>
							<span class="travel-atlas__stat-label">Countries</span>
						</div>
						<div class="travel-atlas__stat">
							<span class="travel-atlas__stat-value">{continentCount}</span>
							<span class="travel-atlas__stat-label">Continents</span>
						</div>
					</div>
				</header>

				<div class="travel-atlas__main">
					<section class="travel-globe" data-travel-globe>
						<div class="travel-globe__header">
							<div>
								<p class="travel-globe__eyebrow">Interactive map</p>
								<h2>Rotate the globe and open a stop</h2>
							</div>
							<p class="travel-globe__hint">Scroll, drag, or tap a marker.</p>
						</div>

						<div class="travel-globe__stage">
							<div class="travel-globe__orbit travel-globe__orbit--outer"></div>
							<div class="travel-globe__orbit travel-globe__orbit--inner"></div>
							<div class="travel-globe__viewport" data-globe-viewport>
								<div class="travel-globe__track" data-globe-track>
									{
										Array.from({ length: 3 }).map((_, segmentIndex) => (
											<div class="travel-globe__segment">
												<div class="travel-globe__map-art" set:html={worldMapMarkup}></div>
												{
													travelStops.map((stop) => (
														<button
															type="button"
															class="travel-globe__marker"
															data-city-marker={stop.id}
															aria-label={`Open ${stop.city}, ${stop.country}`}
															style={`left:${((stop.lng + 180) / 360) * 100}%;top:${((90 - stop.lat) / 180) * 100}%;--marker-accent:${stop.accent};`}
														>
															<span class="sr-only">{stop.city}</span>
															<span class="travel-globe__marker-core"></span>
														</button>
													))
												}
												{
													segmentIndex === 1 && (
														<div class="travel-globe__equator" aria-hidden="true"></div>
													)
												}
											</div>
										))
									}
								</div>
								<div class="travel-globe__shadow"></div>
								<div class="travel-globe__shine"></div>
								<div class="travel-globe__rim"></div>
							</div>
							<div class="travel-globe__footer">
								<p>
									Highlighted markers show visited places. The postcard on the right updates as
									soon as a marker or city chip is selected.
								</p>
							</div>
						</div>
					</section>

					<aside class="travel-postcard is-active" data-postcard aria-live="polite">
						<div class="travel-postcard__pin"></div>
						<div class="travel-postcard__stamp" data-postcard-stamp></div>
						<p class="travel-postcard__label">Selected stop</p>
						<h2 class="travel-postcard__title" data-postcard-title></h2>
						<p class="travel-postcard__meta" data-postcard-meta></p>
						<p class="travel-postcard__summary" data-postcard-summary></p>

						<div class="travel-postcard__media">
							<button type="button" class="travel-postcard__nav" data-photo-prev aria-label="Previous image">
								<span aria-hidden="true">&#8249;</span>
							</button>
							<div class="travel-postcard__photo-frame">
								<img data-postcard-image alt="" loading="lazy" />
								<div class="travel-postcard__photo-tag" data-postcard-photo-tag></div>
							</div>
							<button type="button" class="travel-postcard__nav" data-photo-next aria-label="Next image">
								<span aria-hidden="true">&#8250;</span>
							</button>
						</div>

						<div class="travel-postcard__caption-row">
							<p class="travel-postcard__caption" data-postcard-caption></p>
							<p class="travel-postcard__counter" data-postcard-counter></p>
						</div>

						<div class="travel-postcard__thumbs" data-postcard-thumbs></div>

						<div class="travel-postcard__notes" data-postcard-notes></div>
						<div class="travel-postcard__highlights" data-postcard-highlights></div>
					</aside>
				</div>

				<section class="travel-atlas__index">
					<div class="travel-atlas__index-head">
						<div>
							<p class="travel-atlas__eyebrow">Journey index</p>
							<h2>Browse by country</h2>
						</div>
						<p>Each chip below opens the same postcard module as the map.</p>
					</div>

					<div class="travel-atlas__country-grid">
						{
							groupedStops.map((group) => (
								<article class="travel-country__card" style={`--country-accent:${group.accent};`}>
									<div class="travel-country__head">
										<div>
											<h3>{group.country}</h3>
											<p>{group.continent}</p>
										</div>
										<span class="travel-country__count">
											{group.stops.length} {group.stops.length === 1 ? 'stop' : 'stops'}
										</span>
									</div>
									<div class="travel-country__chips">
										{
											group.stops.map((stop) => (
												<button
													type="button"
													class="travel-country__chip"
													data-city-button={stop.id}
													style={`--chip-accent:${stop.accent};`}
												>
													{stop.city}
												</button>
											))
										}
									</div>
								</article>
							))
						}
					</div>
				</section>
			</div>
		</section>
	</Container>
</Layout>

<script define:vars={{ travelStops, initialStopId: initialStop.id }}>
	const stopById = new Map(travelStops.map((stop) => [stop.id, stop]));
	const globe = document.querySelector('[data-travel-globe]');
	const track = document.querySelector('[data-globe-track]');
	const viewport = document.querySelector('[data-globe-viewport]');
	const postcard = document.querySelector('[data-postcard]');
	const markerButtons = Array.from(document.querySelectorAll('[data-city-marker]'));
	const cityButtons = Array.from(document.querySelectorAll('[data-city-button]'));
	const titleEl = document.querySelector('[data-postcard-title]');
	const metaEl = document.querySelector('[data-postcard-meta]');
	const summaryEl = document.querySelector('[data-postcard-summary]');
	const imageEl = document.querySelector('[data-postcard-image]');
	const tagEl = document.querySelector('[data-postcard-photo-tag]');
	const captionEl = document.querySelector('[data-postcard-caption]');
	const counterEl = document.querySelector('[data-postcard-counter]');
	const notesEl = document.querySelector('[data-postcard-notes]');
	const highlightsEl = document.querySelector('[data-postcard-highlights]');
	const thumbsEl = document.querySelector('[data-postcard-thumbs]');
	const stampEl = document.querySelector('[data-postcard-stamp]');
	const prevPhotoButton = document.querySelector('[data-photo-prev]');
	const nextPhotoButton = document.querySelector('[data-photo-next]');

	let activeCityId = initialStopId;
	let activePhotoIndex = 0;
	let centerLongitude = -74;
	let tilt = 2;
	let isDragging = false;
	let dragMoved = false;
	let lastPointerX = 0;
	let lastPointerY = 0;
	let lastFrame = 0;
	let autoSpin = true;
	let resumeTimer = 0;

	const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
	const normalizeLongitude = (value) => ((value + 180) % 360 + 360) % 360 - 180;

	const updateMarkerState = () => {
		markerButtons.forEach((button) => {
			const isActive = button.dataset.cityMarker === activeCityId;
			button.dataset.active = String(isActive);
			button.setAttribute('aria-pressed', String(isActive));
		});

		cityButtons.forEach((button) => {
			const isActive = button.dataset.cityButton === activeCityId;
			button.dataset.active = String(isActive);
			button.setAttribute('aria-pressed', String(isActive));
		});
	};

	const animatePostcard = () => {
		if (!postcard) return;
		postcard.classList.remove('is-refreshing');
		void postcard.offsetWidth;
		postcard.classList.add('is-refreshing');
	};

	const renderPostcard = () => {
		const stop = stopById.get(activeCityId);
		if (!stop || !titleEl || !metaEl || !summaryEl || !imageEl || !captionEl || !counterEl || !notesEl || !highlightsEl || !thumbsEl || !tagEl || !stampEl) {
			return;
		}

		const totalPhotos = stop.photos.length;
		const photo = stop.photos[activePhotoIndex] ?? stop.photos[0];

		titleEl.textContent = stop.city;
		metaEl.textContent = `${stop.kind} in ${stop.country} · ${stop.continent} · ${stop.lat.toFixed(1)}°, ${stop.lng.toFixed(1)}°`;
		summaryEl.textContent = stop.summary;
		imageEl.setAttribute('src', photo.src);
		imageEl.setAttribute('alt', photo.alt);
		tagEl.textContent = photo.tag;
		captionEl.textContent = photo.caption;
		counterEl.textContent = `${activePhotoIndex + 1} / ${totalPhotos}`;
		stampEl.textContent = stop.country;

		notesEl.replaceChildren(
			...stop.details.map((detail) => {
				const paragraph = document.createElement('p');
				paragraph.textContent = detail;
				return paragraph;
			}),
		);

		highlightsEl.replaceChildren(
			...stop.highlights.map((highlight) => {
				const pill = document.createElement('span');
				pill.className = 'travel-postcard__highlight-pill';
				pill.textContent = highlight;
				pill.style.setProperty('--highlight-accent', stop.accent);
				return pill;
			}),
		);

		thumbsEl.replaceChildren(
			...stop.photos.map((entry, index) => {
				const button = document.createElement('button');
				button.type = 'button';
				button.className = 'travel-postcard__thumb';
				button.dataset.photoIndex = String(index);
				button.dataset.active = String(index === activePhotoIndex);
				button.setAttribute('aria-label', `Show image ${index + 1} for ${stop.city}`);
				button.style.setProperty('--thumb-accent', stop.accent);

				const thumbImage = document.createElement('img');
				thumbImage.src = entry.src;
				thumbImage.alt = entry.alt;
				thumbImage.loading = 'lazy';

				button.appendChild(thumbImage);
				button.addEventListener('click', () => {
					activePhotoIndex = index;
					renderPostcard();
				});

				return button;
			}),
		);

		postcard?.style.setProperty('--postcard-accent', stop.accent);
		animatePostcard();
	};

	const updateTrack = () => {
		if (!track || !viewport) return;
		const middleSegment = track.children[1];
		if (!middleSegment) return;

		const segmentWidth = middleSegment.getBoundingClientRect().width;
		const viewportRect = viewport.getBoundingClientRect();
		const wrappedLongitude = ((centerLongitude + 180) % 360 + 360) % 360;
		const offset = (wrappedLongitude / 360) * segmentWidth - viewportRect.width / 2;
		const verticalShift = (-tilt / 90) * viewportRect.height * 0.36;

		track.style.transform = `translate3d(${-segmentWidth - offset}px, ${verticalShift}px, 0)`;
		globe?.style.setProperty('--globe-tilt', `${tilt * -0.35}deg`);
	};

	const setActiveCity = (cityId) => {
		if (!stopById.has(cityId)) return;
		activeCityId = cityId;
		activePhotoIndex = 0;
		updateMarkerState();
		renderPostcard();
	};

	const pauseSpin = () => {
		autoSpin = false;
		window.clearTimeout(resumeTimer);
		resumeTimer = window.setTimeout(() => {
			autoSpin = true;
		}, 3200);
	};

	const frame = (timestamp) => {
		if (!lastFrame) lastFrame = timestamp;
		const delta = timestamp - lastFrame;
		lastFrame = timestamp;

		if (autoSpin && !isDragging) {
			centerLongitude = normalizeLongitude(centerLongitude + delta * 0.0038);
			updateTrack();
		}

		window.requestAnimationFrame(frame);
	};

	const selectNearbyCity = (button) => {
		if (!button || dragMoved) return;
		const cityId = button.dataset.cityMarker || button.dataset.cityButton;
		if (!cityId) return;
		setActiveCity(cityId);
		pauseSpin();
	};

	markerButtons.forEach((button) => {
		button.addEventListener('click', () => selectNearbyCity(button));
	});

	cityButtons.forEach((button) => {
		button.addEventListener('click', () => selectNearbyCity(button));
	});

	prevPhotoButton?.addEventListener('click', () => {
		const stop = stopById.get(activeCityId);
		if (!stop) return;
		activePhotoIndex = (activePhotoIndex - 1 + stop.photos.length) % stop.photos.length;
		renderPostcard();
		pauseSpin();
	});

	nextPhotoButton?.addEventListener('click', () => {
		const stop = stopById.get(activeCityId);
		if (!stop) return;
		activePhotoIndex = (activePhotoIndex + 1) % stop.photos.length;
		renderPostcard();
		pauseSpin();
	});

	viewport?.addEventListener(
		'wheel',
		(event) => {
			event.preventDefault();
			centerLongitude = normalizeLongitude(centerLongitude + (event.deltaY + event.deltaX) * 0.05);
			tilt = clamp(tilt + event.deltaY * 0.01, -26, 26);
			updateTrack();
			pauseSpin();
		},
		{ passive: false },
	);

	viewport?.addEventListener('pointerdown', (event) => {
		isDragging = true;
		dragMoved = false;
		lastPointerX = event.clientX;
		lastPointerY = event.clientY;
		viewport.setPointerCapture?.(event.pointerId);
		pauseSpin();
	});

	viewport?.addEventListener('pointermove', (event) => {
		if (!isDragging) return;
		const deltaX = event.clientX - lastPointerX;
		const deltaY = event.clientY - lastPointerY;
		if (Math.abs(deltaX) > 2 || Math.abs(deltaY) > 2) {
			dragMoved = true;
		}

		centerLongitude = normalizeLongitude(centerLongitude - deltaX * 0.22);
		tilt = clamp(tilt + deltaY * 0.08, -26, 26);
		lastPointerX = event.clientX;
		lastPointerY = event.clientY;
		updateTrack();
	});

	const endDrag = () => {
		if (!isDragging) return;
		isDragging = false;
		window.setTimeout(() => {
			dragMoved = false;
		}, 20);
	};

	viewport?.addEventListener('pointerup', endDrag);
	viewport?.addEventListener('pointerleave', endDrag);
	viewport?.addEventListener('pointercancel', endDrag);
	window.addEventListener('resize', updateTrack);

	updateMarkerState();
	renderPostcard();
	updateTrack();
	window.requestAnimationFrame(frame);
</script>

<style>
	.travel-atlas {
		margin: var(--section-margin) auto;
	}

	.travel-atlas__shell {
		--atlas-ink: #1b2d34;
		--atlas-ink-soft: rgba(27, 45, 52, 0.72);
		--atlas-line: rgba(27, 45, 52, 0.12);
		--atlas-paper: #f6efe4;
		--atlas-paper-strong: #fff8ef;
		--atlas-ocean: #15384d;
		--atlas-ocean-soft: #23516a;
		--atlas-glow: rgba(255, 218, 152, 0.65);
		position: relative;
		overflow: hidden;
		padding: clamp(1.25rem, 2vw, 2.25rem);
		border-radius: 36px;
		border: 1px solid var(--atlas-line);
		background:
			radial-gradient(circle at top left, rgba(255, 217, 156, 0.42), transparent 30%),
			radial-gradient(circle at bottom right, rgba(74, 126, 140, 0.18), transparent 32%),
			linear-gradient(180deg, #f9f4ec 0%, #efe8dc 100%);
		box-shadow:
			0 28px 70px rgba(38, 55, 64, 0.16),
			inset 0 1px 0 rgba(255, 255, 255, 0.5);
	}

	.travel-atlas__wash {
		position: absolute;
		pointer-events: none;
		border-radius: 999px;
		filter: blur(10px);
		opacity: 0.75;
	}

	.travel-atlas__wash--top {
		top: -5rem;
		left: -2rem;
		width: 18rem;
		height: 18rem;
		background: radial-gradient(circle, rgba(255, 210, 143, 0.55), transparent 68%);
	}

	.travel-atlas__wash--bottom {
		right: -3rem;
		bottom: -5rem;
		width: 20rem;
		height: 20rem;
		background: radial-gradient(circle, rgba(67, 111, 127, 0.24), transparent 70%);
	}

	.travel-atlas__intro,
	.travel-atlas__main,
	.travel-atlas__index {
		position: relative;
		z-index: 1;
	}

	.travel-atlas__intro {
		display: grid;
		grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.7fr);
		gap: 1.5rem;
		align-items: end;
		margin-bottom: 1.5rem;
	}

	.travel-atlas__eyebrow,
	.travel-globe__eyebrow,
	.travel-postcard__label {
		margin: 0 0 0.55rem;
		font-family: var(--theme-font-family-sans);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--atlas-ink-soft);
	}

	.travel-atlas__copy h1 {
		margin-bottom: 0.75rem;
		color: var(--atlas-ink);
	}

	.travel-atlas__lead {
		max-width: 52rem;
		margin-bottom: 0;
		font-size: 1.08rem;
		color: var(--atlas-ink-soft);
	}

	.travel-atlas__facts {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.75rem;
	}

	.travel-atlas__stat {
		padding: 1rem;
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.6);
		border: 1px solid rgba(27, 45, 52, 0.08);
		backdrop-filter: blur(8px);
	}

	.travel-atlas__stat-value {
		display: block;
		font-family: var(--theme-font-family-serif);
		font-size: clamp(2rem, 3vw, 2.8rem);
		line-height: 1;
		color: var(--atlas-ink);
	}

	.travel-atlas__stat-label {
		display: inline-block;
		margin-top: 0.35rem;
		color: var(--atlas-ink-soft);
	}

	.travel-atlas__main {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
		gap: 1.35rem;
		align-items: start;
	}

	.travel-globe,
	.travel-postcard,
	.travel-country__card {
		border: 1px solid rgba(27, 45, 52, 0.09);
		background: rgba(255, 252, 247, 0.78);
		box-shadow: 0 18px 38px rgba(30, 44, 53, 0.08);
	}

	.travel-globe {
		padding: 1.15rem;
		border-radius: 28px;
	}

	.travel-globe__header {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.travel-globe__header h2,
	.travel-atlas__index-head h2 {
		margin-bottom: 0;
		color: var(--atlas-ink);
		font-size: clamp(1.4rem, 2vw, 2rem);
	}

	.travel-globe__hint,
	.travel-atlas__index-head p,
	.travel-country__head p,
	.travel-postcard__meta,
	.travel-postcard__caption,
	.travel-globe__footer p {
		margin-bottom: 0;
		color: var(--atlas-ink-soft);
	}

	.travel-globe__stage {
		position: relative;
		padding: 1rem 0 0;
	}

	.travel-globe__orbit {
		position: absolute;
		inset: 0;
