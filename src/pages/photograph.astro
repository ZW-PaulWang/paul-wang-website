function escapeSvgText(value: string) {
	return value
		.replaceAll('&', '&amp;')
		.replaceAll('<', '&lt;')
		.replaceAll('>', '&gt;')
		.replaceAll('"', '&quot;')
		.replaceAll("'", '&#39;');
}

function createTravelArt(
	city: string,
	country: string,
	palette: ArtPalette,
	headline: string,
	detail: string,
	tag: string,
) {
	const safeCity = escapeSvgText(city);
	const safeCountry = escapeSvgText(country);
	const safeHeadline = escapeSvgText(headline);
	const safeDetail = escapeSvgText(detail);
	const safeTag = escapeSvgText(tag);
	const svg = `
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 620" role="img" aria-label="${safeCity}">
			<rect width="900" height="620" rx="44" fill="${palette.fog}" />
			<rect x="26" y="26" width="848" height="568" rx="32" fill="${palette.skyBottom}" />
			<path d="M26 26H874V326C776 274 706 238 592 256C500 272 428 354 314 348C210 344 136 288 26 316Z" fill="${palette.skyTop}" />
			<circle cx="702" cy="160" r="88" fill="${palette.glow}" fill-opacity="0.42" />
			<path d="M0 426C150 374 228 450 338 410C444 372 526 318 656 352C742 374 814 442 900 424V620H0Z" fill="${palette.ridge}" fill-opacity="0.92" />
			<path d="M0 476C144 430 240 486 338 458C446 428 512 386 644 418C770 450 830 510 900 504V620H0Z" fill="${palette.ink}" fill-opacity="0.25" />
			<rect x="574" y="414" width="214" height="96" rx="24" fill="${palette.fog}" fill-opacity="0.86" stroke="${palette.stamp}" stroke-width="4" stroke-dasharray="12 10" />
			<text x="682" y="452" text-anchor="middle" font-size="18" font-family="Arial, sans-serif" fill="${palette.stamp}" letter-spacing="3">TRAVEL LOG</text>
			<text x="682" y="482" text-anchor="middle" font-size="26" font-family="Arial, sans-serif" font-weight="700" fill="${palette.ink}">${safeTag}</text>
			<text x="70" y="104" font-size="28" font-family="Arial, sans-serif" fill="${palette.fog}" fill-opacity="0.92" letter-spacing="3">POSTCARD SERIES</text>
			<text x="70" y="154" font-size="56" font-family="Georgia, serif" font-weight="700" fill="${palette.fog}">${safeCity}</text>
			<text x="70" y="194" font-size="24" font-family="Arial, sans-serif" fill="${palette.fog}" fill-opacity="0.88">${safeCountry}</text>
			<rect x="70" y="388" width="396" height="124" rx="28" fill="${palette.fog}" fill-opacity="0.84" />
			<text x="102" y="434" font-size="30" font-family="Georgia, serif" font-weight="700" fill="${palette.ink}">${safeHeadline}</text>
			<text x="102" y="474" font-size="20" font-family="Arial, sans-serif" fill="${palette.ink}" fill-opacity="0.8">${safeDetail}</text>
			<text x="102" y="518" font-size="16" font-family="Arial, sans-serif" fill="${palette.ink}" fill-opacity="0.58">Replace with your own travel photos whenever you are ready.</text>
		</svg>
	`;

	return `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(svg)}`;
}

function createPhotoSet(
	city: string,
	country: string,
	palette: ArtPalette,
	frames: Array<{ headline: string; detail: string; tag: string }>,
): TravelPhoto[] {
	return frames.map((frame) => ({
		src: createTravelArt(city, country, palette, frame.headline, frame.detail, frame.tag),
		alt: `${city} postcard placeholder art`,
		caption: frame.detail,
		tag: frame.tag,
	}));
}

