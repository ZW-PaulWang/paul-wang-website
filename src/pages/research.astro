---
import { Container } from '@components/odyssey-theme';
import Layout from '../layouts/Page.astro';

const projects = [
	{
		title: 'Project 1: Market Microstructure and Liquidity',
		summary: 'Empirical analysis of intraday liquidity and price impact.',
		status: 'Ongoing',
		tags: ['High-frequency data', 'Order flow', 'Execution costs'],
		details:
			'This project studies order flow imbalance, spread dynamics, and execution costs using high-frequency transaction data. I focus on identifying robust liquidity predictors across market regimes.',
	},
	{
		title: 'Project 2: Causal Inference in Applied Economics',
		summary: 'Policy evaluation with quasi-experimental methods.',
		status: 'In progress',
		tags: ['Difference-in-differences', 'Event studies', 'Heterogeneity'],
		details:
			'This project uses difference-in-differences and event-study designs to estimate policy effects. Ongoing work includes sensitivity checks and heterogeneous treatment analysis.',
	},
	{
		title: 'Project 3: Machine Learning for Forecasting',
		summary: 'Interpretable forecasting pipelines for structured data.',
		status: 'Active',
		tags: ['Forecasting', 'Calibration', 'Interpretability'],
		details:
			'I compare tree-based and regularized models for forecasting performance, with emphasis on calibration, interpretability, and out-of-sample stability.',
	},
];
---

<Layout
	seo={{
		title: 'Research | Paul (Zechong) Wang',
		description:
			'Research projects by Paul (Zechong) Wang with expandable details.',
	}}
>
	<Container>
		<section class="research-page__section">
			<div class="research-page__hero">
				<div class="research-page__intro glass-card">
					<p class="eyebrow">Research</p>
					<h1>Research</h1>
					<p class="research-page__lede">
						Each project is now grouped into a card with a short summary, method tags, and
						an expandable detail area. The goal is faster scanning with less visual clutter.
					</p>
				</div>
				<aside class="research-page__summary surface-card">
					<p class="eyebrow">At a glance</p>
					<div class="research-page__summary-grid">
						<div class="research-page__summary-item">
							<p class="research-page__summary-label">Topics</p>
							<p>Market microstructure, causal inference, and forecasting.</p>
						</div>
						<div class="research-page__summary-item">
							<p class="research-page__summary-label">Format</p>
							<p>Compact cards with click-to-expand detail instead of a loose stacked list.</p>
						</div>
					</div>
				</aside>
			</div>
			<div class="research-modules__container">
				{
					projects.map((project) => (
						<details class="research-module__item">
							<summary>
								<div class="research-module__topline">
									<p class="eyebrow">{project.status}</p>
									<span class="research-module__toggle">Details</span>
								</div>
								<h2>{project.title}</h2>
								<p class="research-module__summary">{project.summary}</p>
								<div class="research-module__tags">
									{
										project.tags.map((tag) => <span class="research-module__tag">{tag}</span>)
									}
								</div>
							</summary>
							<div class="research-module__details">
								<p class="research-module__detail-label">Overview</p>
								<p>{project.details}</p>
							</div>
						</details>
					))
				}
			</div>
		</section>
	</Container>
</Layout>

<style>
	.research-page__section {
		margin: var(--section-margin) auto;
		display: grid;
		gap: 1.25rem;
	}
	.research-page__hero {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);
		gap: 1.25rem;
	}
	.research-page__intro,
	.research-page__summary {
		padding: 1.4rem;
	}
	.research-page__lede {
		max-width: 38rem;
		color: var(--theme-muted);
	}
	.research-page__summary-grid {
		display: grid;
		gap: 1rem;
	}
	.research-page__summary-label,
	.research-module__detail-label {
		margin-bottom: 0.35rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--theme-muted);
	}
	.research-modules__container {
		display: grid;
		gap: 1.1rem;
	}
	.research-module__item {
		border: 1px solid var(--theme-outline);
		border-radius: calc(var(--theme-shape-radius) * 0.9);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.62)),
			var(--theme-surface-1);
		box-shadow: var(--theme-shadow-md), var(--theme-shadow-inset);
		overflow: hidden;
	}
	.research-module__item summary {
		list-style: none;
		padding: 1.2rem;
		cursor: pointer;
	}
	.research-module__item summary::-webkit-details-marker {
		display: none;
	}
	.research-module__topline {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.research-module__item h2 {
		margin-bottom: 0.45rem;
		font-size: var(--font-size-md);
	}
	.research-module__summary {
		margin-bottom: 0.85rem;
		color: var(--theme-muted);
	}
	.research-module__toggle {
		padding: 0.45rem 0.7rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.55);
		border: 1px solid var(--theme-outline);
		font-size: 0.8rem;
		font-weight: 700;
	}
	.research-module__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}
	.research-module__tag {
		padding: 0.48rem 0.72rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.5);
		border: 1px solid var(--theme-outline);
		font-size: 0.82rem;
		font-weight: 700;
	}
	.research-module__details {
		padding: 0 1.2rem 1.2rem;
		color: var(--theme-muted);
	}
	.research-module__details p:last-child,
	.research-page__summary-item p:last-child {
		margin-bottom: 0;
	}
	.research-module__item[open] {
		border-color: var(--theme-outline-strong);
		box-shadow: var(--theme-shadow-lg), var(--theme-shadow-inset);
	}
	.research-module__item[open] .research-module__toggle {
		background: var(--theme-primary);
		color: var(--theme-on-primary);
		border-color: transparent;
	}
	@media (max-width: 900px) {
		.research-page__hero {
			grid-template-columns: 1fr;
		}
	}
</style>
