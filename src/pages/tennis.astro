---
import { Container } from '@components/odyssey-theme';
import Layout from '../layouts/Page.astro';

const gallery = [
	{
	src: '/assets/images/tennis/uchicago_club.jpg',
	alt: 'Play at UChicago Club Tennis',
	intro: 'After I began my master’s study at the University of Chicago, I had the chance to join the board of the UChicago Club Tennis team and serve as a practice leader. Each week, I lead training sessions for recreational players at different skill levels. My goal is to help more students build their interest in tennis and to share my passion for the sport with them. Being able to teach and play at the same time has made my experience at UChicago even more meaningful.',
	location: 'Chicago, IL, USA',
	tags: ['Practice', 'Matches'],
	},
	{
	src: '/assets/images/home/paul-wang.jpg',
	alt: 'Center Court Moment',
	intro: 'This is my favorite court that I have visited so far. I have never watched a Wimbledon match in person, but when I traveled to London, I signed up for a tour at Wimbledon. Walking around the grounds and seeing the historic courts up close felt surreal. Even without attending a live match, I could feel the tradition and atmosphere that make Wimbledon so special.',
	location: 'Wimbledon, London, UK',
	tags: ['Courts', 'Trips'],
	},
	{
	src: '/assets/images/tennis/gift_racket.jpg',
	alt: 'The Most Special Racket',
	intro: 'The limited edition Wilson Pro Staff v13 was a gift from my roommate James during my time in New York City. This racket is very special to me. It stands out not only because of its unique design and strong performance, but also because it represents our friendship and the many fun matches we played together. The Pro Staff feels exactly as I expected. It is precise and very stable, and the sweet spot feels incredibly clean at contact. I paired it with Hyper G strings, which match the paint design perfectly.',
	location: 'New York City, NY, USA',
	tags: ['Equipment'],
	},
	{
	src: '/assets/images/tennis/hamilton_park.jpg',
	alt: 'The Hidden Gem',
	intro: 'During my time in New York City, I became more and more absorbed in tennis. It was my first time leaving my family and coming to the United States to study. Everything felt new, and at times it was challenging. I was young, and I often felt uncertain and lonely. Tennis became a steady companion during that period. I usually played at Hamilton Park in Jersey City. The park is beautiful, and the courts are much less crowded than those in Manhattan. I have many meaningful memories there.',
	location: 'Jersey City, NJ, USA',
	tags: ['Courts']
	},	
	{
	src: '/assets/images/tennis/second_racket.jpg',
	alt: 'The "Real" Racket',
	intro: 'I stopped playing tennis for a few years during high school, but I returned to the sport in college. That was when I bought my first real adult racket, the Head Gravity Tour. It feels very soft at contact, and the sweet spot is large and forgiving. It suits my backhand very well. I also really like the paint job. Owning this racket made me feel that I was taking tennis more seriously again.',
	location: 'New York City, NY, USA',
	tags: ['Equipment'],
	},
	{
	src: '/assets/images/tennis/childhood.jpg',
	alt: 'Childhood',
	intro: 'This photo shows me at 12 years old hitting my "signature backhand". I started playing tennis when I was 9. My mom signed me up for lessons because she wanted me to get more exercise. Soon after, I fell in love with the sport and I have played ever since. I was using a Head Airflow racket. The head size was very large, so the sweet spot felt huge. It was also very light, which made it easy for me to swing. At that time, I trained once a week with my coach.',
	location: 'Shanghai, China',
	tags: ['Practice', 'Equipment'],
	},
];

const tennisTags = ['All', ...new Set(gallery.flatMap((item) => item.tags || []))];
---

<Layout
	hideFooter
	immersiveHeader
	seo={{
		title: 'Tennis | Paul (Zechong) Wang',
		description: 'Tennis gallery and story-style highlights by Paul Wang.',
	}}
>
	<section class="tennis-hero" aria-labelledby="tennis-title">
		<img
			class="tennis-hero__image"
			src="/assets/images/tennis/tennis-hero-generated.png"
			alt="A quiet tennis court with a racket and tennis balls near the sideline."
		/>
		<div class="tennis-hero__overlay" aria-hidden="true"></div>
		<div class="tennis-hero__content">
			<div class="tennis-hero__rule" aria-hidden="true"></div>
			<p class="tennis-hero__eyebrow">Courts, practice, equipment</p>
			<h1 id="tennis-title">Tennis</h1>
			<p>
				Match, training, courts, equipment updates.
			</p>
		</div>
	</section>

	<section class="tennis-gallery-band" aria-label="Tennis stories">
		<Container>
			<div class="tennis-gallery__header">
				<h2>Selected memories</h2>
			</div>

			<div class="story-highlights__row">
				{
					tennisTags.map((tag) => (
						<button
							type="button"
							class={`story-chip ${tag === 'All' ? 'story-chip--active' : ''}`}
							data-tennis-filter-tag={tag}
						>
							{tag}
						</button>
					))
				}
			</div>

			<div class="gallery-grid__container">
				{
					gallery.map((item, index) => (
						<article
							class={`gallery-card__item ${index === 0 ? 'gallery-card__item--featured' : ''}`}
							data-tennis-card
							data-tennis-card-tags={(item.tags || []).join('|').toLowerCase()}
						>
							<button
								type="button"
								class="gallery-card__button"
								data-tennis-photo-index={index}
							>
								<img src={item.src} alt={item.alt} loading="lazy" />
								<span class="gallery-card__scrim" aria-hidden="true" />
								<span class="gallery-card__copy">
									<span class="gallery-card__location">{item.location}</span>
									<strong>{item.alt}</strong>
									<span>{(item.tags || []).join(' / ')}</span>
								</span>
							</button>
						</article>
					))
				}
			</div>

			<dialog id="tennisDialog" class="post-dialog__container">
				<button type="button" class="dialog-close__button" id="tennisDialogClose">
					Close
				</button>
				<img id="tennisDialogImage" alt="" />
				<h2 id="tennisDialogTitle"></h2>
				<p id="tennisDialogIntro"></p>
				<p><strong>Where:</strong> <span id="tennisDialogLocation"></span></p>
				<p><strong>Tags:</strong> <span id="tennisDialogTags"></span></p>
			</dialog>
		</Container>
	</section>
</Layout>

<script define:vars={{ gallery }}>
	const tennisDialog = document.querySelector('#tennisDialog');
	const tennisDialogClose = document.querySelector('#tennisDialogClose');
	const tennisDialogImage = document.querySelector('#tennisDialogImage');
	const tennisDialogTitle = document.querySelector('#tennisDialogTitle');
	const tennisDialogIntro = document.querySelector('#tennisDialogIntro');
	const tennisDialogLocation = document.querySelector('#tennisDialogLocation');
	const tennisDialogTags = document.querySelector('#tennisDialogTags');
	const tennisButtons = document.querySelectorAll('[data-tennis-photo-index]');
	const tagButtons = document.querySelectorAll('[data-tennis-filter-tag]');
	const tennisCards = document.querySelectorAll('[data-tennis-card]');

	tennisButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const index = Number(button.getAttribute('data-tennis-photo-index'));
			const item = gallery[index];
			if (!item || !tennisDialog) return;
			tennisDialogImage.setAttribute('src', item.src);
			tennisDialogImage.setAttribute('alt', item.alt);
			tennisDialogTitle.textContent = item.alt;
			tennisDialogIntro.textContent = item.intro;
			tennisDialogLocation.textContent = item.location;
			tennisDialogTags.textContent = (item.tags || []).join(', ');
			tennisDialog.showModal();
		});
	});

	tennisDialogClose?.addEventListener('click', () => {
		tennisDialog?.close();
	});

	tagButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const selectedTag = (button.getAttribute('data-tennis-filter-tag') || 'All').toLowerCase();

			tagButtons.forEach((chip) => chip.classList.remove('story-chip--active'));
			button.classList.add('story-chip--active');

			tennisCards.forEach((card) => {
				if (selectedTag === 'all') {
					card.removeAttribute('hidden');
					return;
				}
				const tags = card.getAttribute('data-tennis-card-tags') || '';
				if (tags.split('|').includes(selectedTag)) {
					card.removeAttribute('hidden');
				} else {
					card.setAttribute('hidden', 'true');
				}
			});
		});
	});
</script>

<style>
	.tennis-hero {
		--tennis-ink: #071725;
		--tennis-teal: #17424b;
		--tennis-accent: #d78370;
		position: relative;
		isolation: isolate;
		width: 100vw;
		min-height: clamp(42rem, 86svh, 58rem);
		margin-left: calc(50% - 50vw);
		overflow: hidden;
		background: #ffffff;
	}
	.tennis-hero__image {
		position: absolute;
		inset: 0;
		z-index: 0;
		width: 100%;
		height: 100%;
		max-width: none;
		object-fit: cover;
		object-position: center 42%;
		filter: saturate(0.98) contrast(1.03);
	}
	.tennis-hero__overlay {
		position: absolute;
		inset: 0;
		z-index: 1;
		background:
			linear-gradient(90deg, rgba(255, 255, 255, 0.95) 0%, rgba(255, 255, 255, 0.86) 32%, rgba(255, 255, 255, 0.36) 58%, rgba(255, 255, 255, 0.04) 100%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.02) 0%, rgba(255, 255, 255, 0.88) 100%);
		pointer-events: none;
	}
	.tennis-hero__content {
		position: absolute;
		left: max(
			clamp(1.5rem, 7vw, 6rem),
			calc((100vw - var(--container-max-width)) / 2 + 1.5rem)
		);
		bottom: clamp(3rem, 8vw, 6.8rem);
		z-index: 2;
		width: min(37rem, calc(100vw - 3rem));
		color: var(--tennis-ink);
	}
	.tennis-hero__rule {
		width: 5rem;
		height: 2px;
		margin-bottom: 1.55rem;
		background: var(--tennis-accent);
	}
	.tennis-hero__eyebrow {
		margin-bottom: 0.8rem;
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--tennis-teal);
	}
	.tennis-hero h1 {
		max-width: 9ch;
		margin-bottom: 1.15rem;
		font-family: Georgia, 'Times New Roman', serif;
		font-size: clamp(4.5rem, 10vw, 8rem);
		font-weight: 600;
		line-height: 0.92;
		letter-spacing: 0;
		color: var(--tennis-ink);
	}
	.tennis-hero__content p:last-child {
		max-width: 29rem;
		margin: 0;
		font-size: clamp(1.03rem, 1.32vw, 1.24rem);
		line-height: 1.7;
		color: #102b36;
	}
	.tennis-gallery-band {
		--tennis-ink: #071725;
		--tennis-teal: #17424b;
		--tennis-accent: #d78370;
		position: relative;
		width: 100vw;
		margin-left: calc(50% - 50vw);
		padding: clamp(4.5rem, 7vw, 7rem) 0 clamp(5rem, 8vw, 8rem);
		overflow: hidden;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(237, 248, 251, 0.72) 24rem),
			linear-gradient(135deg, rgba(23, 66, 75, 0.08), rgba(215, 131, 112, 0.06) 48%, rgba(255, 255, 255, 0.76)),
			#fbfbfa;
	}
	.tennis-gallery-band::after {
		content: '';
		position: absolute;
		inset: 0;
		background-image: linear-gradient(
			90deg,
			transparent 0,
			transparent calc(50% - min(640px, 43vw)),
			rgba(7, 23, 37, 0.052) calc(50% - min(640px, 43vw)),
			rgba(7, 23, 37, 0.052) calc(50% - min(640px, 43vw) + 1px),
			transparent calc(50% - min(640px, 43vw) + 1px),
			transparent calc(50% + min(640px, 43vw)),
			rgba(7, 23, 37, 0.052) calc(50% + min(640px, 43vw)),
			rgba(7, 23, 37, 0.052) calc(50% + min(640px, 43vw) + 1px),
			transparent calc(50% + min(640px, 43vw) + 1px)
		);
		pointer-events: none;
	}
	.tennis-gallery__header,
	.story-highlights__row,
	.gallery-grid__container,
	.post-dialog__container {
		position: relative;
		z-index: 1;
	}
	.tennis-gallery__header {
		margin-bottom: 1.75rem;
		padding-bottom: 1.35rem;
		border-bottom: 1px solid rgba(23, 23, 23, 0.12);
	}
	.tennis-gallery__header h2 {
		margin: 0;
		font-family: Georgia, 'Times New Roman', serif;
		font-size: clamp(2.55rem, 4.8vw, 4.4rem);
		font-weight: 600;
		line-height: 1;
		letter-spacing: 0;
		color: var(--tennis-ink);
		text-wrap: balance;
	}
	.story-highlights__row {
		margin: 0 0 1.4rem;
		display: flex;
		gap: 0.6rem 1.15rem;
		flex-wrap: wrap;
	}
	.story-chip {
		padding: 0.15rem 0 0.28rem;
		border: 0;
		border-bottom: 1px solid transparent;
		background: transparent;
		color: #56666f;
		cursor: pointer;
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}
	.story-chip--active {
		color: var(--tennis-teal);
		border-color: var(--tennis-accent);
	}
	.gallery-grid__container {
		display: grid;
		grid-template-columns: repeat(6, minmax(0, 1fr));
		grid-auto-flow: dense;
		gap: clamp(0.7rem, 1.5vw, 1rem);
	}
	.gallery-card__item {
		min-height: 18rem;
		grid-column: span 2;
		overflow: hidden;
		border-radius: 0.35rem;
		box-shadow: 0 18px 48px rgba(7, 23, 37, 0.08);
	}
	.gallery-card__item--featured {
		grid-column: span 4;
		grid-row: span 2;
		min-height: 38rem;
	}
	.gallery-card__item:nth-child(4) {
		grid-column: span 3;
	}
	.gallery-card__item:nth-child(5) {
		grid-column: span 3;
	}
	.gallery-card__item[hidden] {
		display: none;
	}
	.gallery-card__button {
		position: relative;
		width: 100%;
		height: 100%;
		min-height: inherit;
		padding: 0;
		margin: 0;
		border: 0;
		background: #dfe9e7;
		cursor: pointer;
		overflow: hidden;
		text-align: left;
		color: #ffffff;
	}
	.gallery-card__item img {
		width: 100%;
		height: 100%;
		max-width: none;
		object-fit: cover;
		display: block;
		filter: saturate(0.96) contrast(1.02);
		transition: transform 360ms ease;
	}
	.gallery-card__button:hover img {
		transform: scale(1.035);
	}
	.gallery-card__scrim {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(180deg, rgba(7, 23, 37, 0.02) 35%, rgba(7, 23, 37, 0.7) 100%),
			linear-gradient(90deg, rgba(7, 23, 37, 0.18), rgba(7, 23, 37, 0));
		pointer-events: none;
	}
	.gallery-card__copy {
		position: absolute;
		left: clamp(1rem, 2vw, 1.35rem);
		right: clamp(1rem, 2vw, 1.35rem);
		bottom: clamp(1rem, 2vw, 1.35rem);
		display: grid;
		gap: 0.35rem;
		text-shadow: 0 1px 14px rgba(7, 23, 37, 0.4);
	}
	.gallery-card__copy strong {
		margin: 0;
		font-family: var(--theme-font-family-serif);
		font-size: clamp(1.35rem, 2vw, 1.95rem);
		line-height: 1.05;
		color: #ffffff;
	}
	.gallery-card__copy span:last-child,
	.gallery-card__location {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.09em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.82);
	}
	.post-dialog__container {
		width: min(820px, 92vw);
		border: 1px solid rgba(255, 255, 255, 0.62);
		border-radius: 0.45rem;
		padding: 1rem 1rem 1.25rem;
		color: #102b36;
		background: rgba(255, 255, 255, 0.94);
		box-shadow: 0 30px 80px rgba(7, 23, 37, 0.28);
	}
	.post-dialog__container::backdrop {
		background: rgba(7, 23, 37, 0.54);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}
	.post-dialog__container img {
		width: 100%;
		max-height: 460px;
		object-fit: cover;
		border-radius: 0.35rem;
		margin-bottom: 1rem;
	}
	.post-dialog__container h2 {
		margin-bottom: 0.65rem;
		font-family: Georgia, 'Times New Roman', serif;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1;
		color: #071725;
	}
	.post-dialog__container p {
		color: #435560;
	}
	.dialog-close__button {
		border: 0;
		border-bottom: 1px solid color-mix(in srgb, var(--tennis-accent) 68%, transparent);
		background: transparent;
		border-radius: 0;
		padding: 0 0 0.25rem;
		cursor: pointer;
		margin-bottom: 0.75rem;
		color: var(--tennis-teal);
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}
	:global(.tiktok-embed) {
		margin: 1rem auto 0;
		max-width: 605px;
		min-width: 325px;
	}
	@media (max-width: 980px) {
		.tennis-hero {
			min-height: clamp(38rem, 84svh, 48rem);
		}
		.tennis-hero__overlay {
			background:
				linear-gradient(180deg, rgba(255, 255, 255, 0.02) 0%, rgba(255, 255, 255, 0.96) 78%),
				linear-gradient(90deg, rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0));
		}
		.gallery-grid__container {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
		.gallery-card__item,
		.gallery-card__item:nth-child(4),
		.gallery-card__item:nth-child(5) {
			grid-column: span 1;
			min-height: 18rem;
		}
		.gallery-card__item--featured {
			grid-column: 1 / -1;
			min-height: 30rem;
		}
	}
	@media (max-width: 768px) {
		.gallery-grid__container {
			grid-template-columns: 1fr;
		}
		.gallery-card__item,
		.gallery-card__item:nth-child(4),
		.gallery-card__item:nth-child(5),
		.gallery-card__item--featured {
			grid-column: 1 / -1;
			min-height: 24rem;
		}
	}
	@media (max-width: 640px) {
		.tennis-hero {
			min-height: clamp(34rem, 82svh, 42rem);
		}
		.tennis-hero h1 {
			font-size: clamp(3.4rem, 17vw, 5rem);
		}
	}
</style>
